{
  "name": "codex-usage-wrapper",
  "version": "0.1.0",
  "private": true,
  "productName": "Codex Claude Usage",
  "author": "CodexUsage",
  "license": "MIT",
  "description": "Local Codex CLI usage wrapper and dashboard.",
  "main": "src/electron/main.js",
  "scripts": {
    "app": "electron .",
    "app:electron": "electron .",
    "app:legacy-tray": "powershell -NoProfile -ExecutionPolicy Bypass -STA -File scripts/native-usage-tray.ps1",
    "app:lite": "powershell -NoProfile -ExecutionPolicy Bypass -STA -File scripts/native-usage-tray.ps1",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis",
    "dist:electron": "electron-builder --win nsis",
    "dist:installer": "electron-builder --win nsis",
    "dist:legacy-native": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-native-installer.ps1",
    "dist:native": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-native-installer.ps1",
    "dist:portable": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-native-exe.ps1",
    "wrapper": "node src/node/codex-wrapper.js",
    "status-poller": "node src/node/codex-status-poller.js",
    "dashboard": "uvicorn --app-dir src/python codex_dashboard_fastapi:app --host 0.0.0.0 --port 8767",
    "dashboard:dev": "uvicorn --app-dir src/python codex_dashboard_fastapi:app --reload --host 0.0.0.0 --port 8767",
    "dashboard:legacy": "python src/python/codex_status_dashboard.py --serve",
    "test": "node tests/run-tests.js"
  },
  "dependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "local.codex-claude-usage",
    "productName": "Codex Claude Usage",
    "asar": false,
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "package.json",
      "assets/**/*",
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "icon": "assets/codex-claude-usage.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/codex-claude-usage.ico",
      "uninstallerIcon": "assets/codex-claude-usage.ico"
    }
  }
}
